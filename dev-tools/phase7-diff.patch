+  };
+}
+
+const shift1 = makeShift('s1', 'Corey Trussell', '2026-07-04T15:00:00Z', '2026-07-04T19:30:00Z');
+const shift2 = makeShift('s2', 'Aleah Holderread', '2026-07-05T18:00:00Z', '2026-07-05T23:30:00Z');
