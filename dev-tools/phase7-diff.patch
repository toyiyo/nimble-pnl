+}
+
+function makeShift(overrides: Partial<Shift> & { id: string; shift_template_id: string }): Shift {
+  return {
+    restaurant_id: 'r1',
+    employee_id: 'e1',
+    start_time: '2026-07-06T15:00:00Z',
+    end_time: '2026-07-06T23:00:00Z',
