+
+import { TemplateRowHeader } from '@/components/scheduling/ShiftPlanner/TemplateRowHeader';
+import type { ShiftTemplate } from '@/types/scheduling';
+
+const baseTemplate: ShiftTemplate = {
+  id: 'tmpl-1',
+  restaurant_id: 'rest-1',
+  name: 'Morning Line',
